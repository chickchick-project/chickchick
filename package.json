{
  "name": "chickchick",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true prisma generate && cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "zod": "zod-prisma-types && node -e \"const fs=require('fs');['prisma/zod/inputTypeSchemas/JsonNullValueFilterSchema.ts','prisma/zod/inputTypeSchemas/NullableJsonNullValueInputSchema.ts'].forEach(f=>{let c=fs.readFileSync(f,'utf8');if(!c.includes('@prisma/client'))c=c.replace(\\\"import { z } from 'zod';\\\",\\\"import { z } from 'zod';\\\\nimport { Prisma } from '@prisma/client';\\\");c=c.replace(/: z\\\\.ZodType<Prisma\\\\.[A-Za-z]+>/g,'');fs.writeFileSync(f,c);});\""
  },
