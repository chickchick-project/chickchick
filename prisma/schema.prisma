generator client {
  provider = "prisma-client-js"
}

generator zod {
  provider          = "zod-prisma-types"
  output            = "./zod"
  createInputTypes  = "false"
  createModelSchema = "true"
  useMultipleFiles  = "true"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model RawPerfume {
  id          String   @id @default(uuid()) @db.Uuid
  perfumeName String   @map("perfume_name")
  brandName   String   @map("brand_name")
  pageUrl     String   @unique @map("page_url")
  imageUrl    String?  @map("image_url")
  accords     String[]
  notes       Json?

  @@map("raw_perfume")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  description String?
  imageUrl    String?   @map("image_url")
  mapLocation Json?     @map("map_location")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  nameEn      String    @unique @map("name_en")
  nameKo      String?   @unique @map("name_ko")
  brandUrl    String?   @map("brand_url")
  perfumes    Perfume[] @relation("BrandToPerfumes")

  @@map("brands")
}

model PerfumeAccord {
  id             String                 @id @default(uuid()) @db.Uuid
  nameKo         String?                @unique @map("name_ko")
  nameEn         String                 @unique @map("name_en")
  description    String?
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  accordMappings PerfumeAccordMapping[] @relation("PerfumeAccordToMappings")

  @@map("perfume_accords")
}

model PerfumeNote {
  id           String               @id @default(uuid()) @db.Uuid
  nameKo       String?              @map("name_ko")
  nameEn       String               @unique @map("name_en")
  description  String?
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  noteMappings PerfumeNoteMapping[] @relation("PerfumeNoteToMappings")

  @@map("perfume_notes")
}

model Perfume {
  id               String                 @id @default(uuid()) @db.Uuid
  brandId          String                 @map("brand_id") @db.Uuid
  officialUrl      String?                @map("official_url")
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  nameEn           String                 @unique @map("name_en")
  nameKo           String?                @unique @map("name_ko")
  accordMappings   PerfumeAccordMapping[] @relation("PerfumeToAccordMappings")
  bookmarks        PerfumeBookmark[]      @relation("PerfumeToBookmarks")
  likedByUsers     PerfumeLike[]          @relation("PerfumeToLikes")
  noteMappings     PerfumeNoteMapping[]   @relation("PerfumeToNoteMappings")
  brand            Brand                  @relation("BrandToPerfumes", fields: [brandId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  perfumeImage     PerfumeImage?          @relation("PerfumeToImage")
  perfumeMappings  PostPerfumeMapping[]   @relation("PerfumeToPostMappings")
  recentViews      RecentPerfumeView[]
  reviews          Review[]               @relation("PerfumeToReviews")
  collectedByUsers UserCollection[]       @relation("PerfumeToUserCollections")

  @@map("perfumes")
}

model User {
  id                   String              @id @default(uuid()) @db.Uuid
  name                 String
  authId               String              @unique @map("auth_id") @db.Uuid
  email                String?             @unique
  nickname             String              @unique
  age                  Int?
  gender               Gender              @default(UNKNOWN)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  isActive             Boolean             @default(true) @map("is_active")
  role                 String?             @default("user")
  imageUrl             String?             @map("image_url")
  deletedAt            DateTime?           @map("deleted_at") @db.Timestamptz(6)
  consecutiveLoginDays Int                 @default(0) @map("consecutive_login_days")
  lastLoginDate        DateTime?           @map("last_login_date") @db.Timestamptz(6)
  totalPoints          Int                 @default(0) @map("total_points")
  comments             Comment[]           @relation("UserToComments")
  perfumeBookmarks     PerfumeBookmark[]   @relation("UserToPerfumeBookmarks")
  perfumeLikes         PerfumeLike[]       @relation("UserToPerfumeLikes")
  pointHistories       PointHistory[]      @relation("UserToPointHistories")
  postBookmarks        PostBookmark[]      @relation("UserToPostBookmarks")
  postLikes            PostLike[]          @relation("UserToPostLikes")
  posts                Post[]              @relation("UserToPosts")
  recentPerfumeViews   RecentPerfumeView[]
  recentPostViews      RecentPostView[]
  reviewLikes          ReviewLike[]        @relation("UserToReviewLikes")
  reviews              Review[]            @relation("UserToReviews")
  activities           UserActivity[]      @relation("UserToActivities")
  collections          UserCollection[]    @relation("UserToCollections")

  @@map("users")
}

model PerfumeLike {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  perfumeId String   @map("perfume_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  perfume   Perfume  @relation("PerfumeToLikes", fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation("UserToPerfumeLikes", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, perfumeId], name: "perfume_likes_user_id_perfume_id_key")
  @@map("perfume_likes")
}

model PerfumeAccordMapping {
  id        String        @id @default(uuid()) @db.Uuid
  perfumeId String        @map("perfume_id") @db.Uuid
  accordId  String        @map("accord_id") @db.Uuid
  accord    PerfumeAccord @relation("PerfumeAccordToMappings", fields: [accordId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  perfume   Perfume       @relation("PerfumeToAccordMappings", fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([perfumeId, accordId], name: "perfume_accord_mappings_perfume_id_accord_id_key")
  @@map("perfume_accord_mappings")
}

model PerfumeNoteMapping {
  id        String      @id @default(uuid()) @db.Uuid
  perfumeId String      @map("perfume_id") @db.Uuid
  noteId    String      @map("note_id") @db.Uuid
  noteStage NoteStage   @default(NONE) @map("note_stage")
  note      PerfumeNote @relation("PerfumeNoteToMappings", fields: [noteId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  perfume   Perfume     @relation("PerfumeToNoteMappings", fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([perfumeId, noteId], name: "perfume_note_mappings_perfume_id_note_id_key")
  @@map("perfume_note_mappings")
}

model UserActivity {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  action     ActivityAction     @map("action")
  targetType ActivityTargetType @map("target_type")
  targetId   String             @map("target_id") @db.Uuid
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User               @relation("UserToActivities", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_activities")
}

model PerfumeBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  perfumeId String   @map("perfume_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  isPublic  Boolean  @default(true)
  perfume   Perfume  @relation("PerfumeToBookmarks", fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation("UserToPerfumeBookmarks", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, perfumeId], name: "perfume_bookmarks_user_id_perfume_id_key")
  @@map("perfume_bookmarks")
}

model UserCollection {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  perfumeId String           @map("perfume_id") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  isPublic  Boolean          @default(true)
  comment   String?
  image     CollectionImage? @relation("CollectionToImage")
  perfume   Perfume          @relation("PerfumeToUserCollections", fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User             @relation("UserToCollections", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, perfumeId], name: "user_collections_user_id_perfume_id_key")
  @@map("user_collections")
}

model PostPerfumeMapping {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  perfumeId String   @map("perfume_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  perfume   Perfume  @relation("PerfumeToPostMappings", fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  post      Post     @relation("PostToPerfumeMappings", fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([postId, perfumeId], name: "post_perfume_mappings_post_id_perfume_id_key")
  @@map("post_perfume_mappings")
}

model PostBookmark {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  post      Post     @relation("PostToBookmarks", fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation("UserToPostBookmarks", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, postId], name: "post_bookmarks_user_id_post_id_key")
  @@map("post_bookmarks")
}

model PostLike {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  post      Post     @relation("PostToLikes", fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation("UserToPostLikes", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, postId], name: "post_likes_user_id_post_id_key")
  @@map("post_likes")
}

model Post {
  id              String               @id @default(uuid()) @db.Uuid
  title           String
  content         String
  userId          String               @map("user_id") @db.Uuid
  category        PostCategory         @default(FREEBOARD)
  published       Boolean              @default(true)
  viewCount       Int                  @default(0) @map("view_count")
  likeCount       Int                  @default(0) @map("like_count")
  commentCount    Int                  @default(0) @map("comment_count")
  thumbnailUrl    String?              @map("thumbnail_url")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?            @updatedAt @map("updated_at") @db.Timestamptz(6)
  contentText     String
  comments        Comment[]            @relation("PostToComments")
  bookmarks       PostBookmark[]       @relation("PostToBookmarks")
  likes           PostLike[]           @relation("PostToLikes")
  perfumeMappings PostPerfumeMapping[] @relation("PostToPerfumeMappings")
  author          User                 @relation("UserToPosts", fields: [userId], references: [id], onDelete: Cascade)
  recentViews     RecentPostView[]

  @@map("posts")
}

model Review {
  id                  String                     @id @default(uuid()) @db.Uuid
  content             String
  authorId            String                     @map("author_id") @db.Uuid
  perfumeId           String                     @map("perfume_id") @db.Uuid
  usageStatus         PerfumeUsageStatus         @default(NOT_USED_YET) @map("usage_status")
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  attributeSelections ReviewAttributeSelection[]
  likes               ReviewLike[]               @relation("ReviewToLikes")
  author              User                       @relation("UserToReviews", fields: [authorId], references: [id], onDelete: Cascade)
  perfume             Perfume                    @relation("PerfumeToReviews", fields: [perfumeId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model ReviewLike {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  reviewId String @map("review_id") @db.Uuid
  review   Review @relation("ReviewToLikes", fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation("UserToReviewLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId], name: "review_likes_user_id_review_id_key")
  @@map("review_likes")
}

model ReviewAttribute {
  id      Int               @id @default(autoincrement())
  key     String            @unique
  name    String
  options AttributeOption[]

  @@map("review_attributes")
}

model AttributeOption {
  id          Int                        @id @default(autoincrement())
  value       String
  name        String
  attributeId Int                        @map("attribute_id")
  attribute   ReviewAttribute            @relation(fields: [attributeId], references: [id])
  selections  ReviewAttributeSelection[]

  @@unique([attributeId, value], name: "attribute_options_attribute_id_value_key")
  @@map("attribute_options")
}

model ReviewAttributeSelection {
  reviewId          String          @map("review_id") @db.Uuid
  attributeOptionId Int             @map("attribute_option_id")
  option            AttributeOption @relation(fields: [attributeOptionId], references: [id])
  review            Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([reviewId, attributeOptionId])
  @@map("review_attribute_selections")
}

model Comment {
  id        String    @id @default(uuid()) @db.Uuid
  content   String
  authorId  String    @map("author_id") @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  postId    String    @map("post_id") @db.Uuid
  published Boolean   @default(true)
  author    User      @relation("UserToComments", fields: [authorId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("CommentToReplies", fields: [parentId], references: [id], onDelete: NoAction)
  replies   Comment[] @relation("CommentToReplies")
  post      Post      @relation("PostToComments", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
  @@map("comments")
}

model PerfumeImage {
  id        String   @id @default(uuid()) @db.Uuid
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  perfumeId String   @unique @map("perfume_id") @db.Uuid
  perfume   Perfume  @relation("PerfumeToImage", fields: [perfumeId], references: [id])

  @@map("perfumes_image")
}

model CollectionImage {
  id           String         @id @default(uuid()) @db.Uuid
  imageUrl     String         @map("image_url")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  collectionId String         @unique @map("collection_id") @db.Uuid
  format       ImageFormat    @default(UNKNOWN)
  height       Int
  width        Int
  collection   UserCollection @relation("CollectionToImage", fields: [collectionId], references: [id], onDelete: Cascade)

  @@map("collection_image")
}

model RecentPerfumeView {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  perfumeId String   @map("perfume_id") @db.Uuid
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)
  perfume   Perfume  @relation(fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, perfumeId], name: "recent_perfume_user_id_perfume_id_key")
  @@index([userId, viewedAt])
  @@map("recent_perfume_views")
}

model RecentPostView {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  postId   String   @map("post_id") @db.Uuid
  viewedAt DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, postId], name: "recent_post_user_id_post_id_key")
  @@index([userId, viewedAt])
  @@map("recent_post_views")
}

model PointHistory {
  id           String            @id @default(uuid()) @db.Uuid
  userId       String            @map("user_id") @db.Uuid
  pointAmount  Int               @map("point_amount")
  activityType PointActivityType @map("activity_type")
  referenceId  String?           @map("reference_id") @db.Uuid
  description  String?
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User              @relation("UserToPointHistories", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([activityType])
  @@map("point_histories")
}

enum ImageFormat {
  JPEG
  PNG
  WEBP
  HEIC
  UNKNOWN
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum ActivityAction {
  CREATED
  LIKED
}

enum ActivityTargetType {
  REVIEW
  POST
  COMMENT
  PERFUME
}

enum BookmarkItemType {
  POST
  PERFUME
}

enum PostCategory {
  QUESTION
  FREEBOARD
  RECOMMENDATION
}

enum NoteStage {
  TOP
  MIDDLE
  BASE
  NONE
}

enum PerfumeUsageStatus {
  CURRENTLY_USING
  USED_BEFORE
  NOT_USED_YET
}

enum PointActivityType {
  CREATE_POST
  CREATE_COMMENT
  LIKE_POST
  CONSECUTIVE_LOGIN_2
  CONSECUTIVE_LOGIN_3
  CONSECUTIVE_LOGIN_7
}
