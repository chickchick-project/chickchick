generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Brand {
  id           String     @id @default(uuid()) @db.Uuid
  name         Json      
  description  String?
  imageUrl     String?    @map("image_url")
  mapLocation  Json?      @map("map_location")
  perfumes     Perfume[]

  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("brands")
}

model PerfumeAccords {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 Json                   @unique
  description          String?
  perfumes_accords_map PerfumeAccordsMap[]
}

model PerfumeNotes {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               Json                 @unique
  description        String?
  perfumes_notes_map PerfumeNotesMap[]
}

model Perfume {
  id                         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                       Json
  brand_id                   String                       @db.Uuid
  price                      Int?
  imageUrl                   String?                      @map("image_url")
  description                String?
  createdAt                  DateTime                     @default(now()) @db.Timestamptz(6)
  officialUrl               String? @map("official_url")
  brand                      Brand                       @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  perfumes_accords_map       PerfumeAccordsMap[]
  perfumes_notes_map         PerfumeNotesMap[]
  userCollections           UserCollection[]
}

model PerfumeAccordsMap {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  perfumeId      String          @db.Uuid @map("perfume_id")
  accordId       String          @db.Uuid @map("accord_id")
  perfumeAccords PerfumeAccords @relation(fields: [accordId], references: [id], onDelete: Cascade, onUpdate: NoAction) 
  perfumes        Perfume        @relation(fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([perfumeId, accordId])
}

model PerfumeNotesMap {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  perfumeId    String        @db.Uuid @map("perfume_id")
  noteId       String        @db.Uuid @map("note_id")
  noteStage    String        @db.VarChar @map("note_stage")
  perfumeNotes PerfumeNotes @relation(fields: [noteId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  perfumes      Perfume      @relation(fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([perfumeId, noteId, noteStage])
}

model RawPerfume {
  id              Int       @id @default(autoincrement())
  perfumeName    String @map("perfume_name")
  brandName      String @map("brand_name")
  pageUrl        String    @unique @map("page_url")
  imageUrl       String? @map("image_url")
  accords         String[]
  notes           Json?
  createdAt      DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")
}

model UserActivity {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?   @db.Uuid @map("user_id")
  activityType String?
  targetId     String    @db.Uuid @map("target_id")
  createdAt    DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")
  users         User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model UserBookmark {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @db.Uuid @map("user_id")
  itemId    String    @db.Uuid @map("item_id")
  itemType  String?   @db.VarChar @map("item_type")
  createdAt DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")
  users      User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, itemId, itemType])
}

model UserCollection {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @db.Uuid @map("user_id")
  perfumeId String?   @db.Uuid @map("perfume_id")
  createdAt DateTime? @default(now()) @db.Timestamptz(6) @map("created_at")
  perfumes   Perfume? @relation(fields: [perfumeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, perfumeId])
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model User {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  authId           String             @unique @db.Uuid @map("auth_id")
  email            String?            @unique
  nickname         String             @unique
  age              Int?
  gender           Gender             @default(UNKNOWN)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)  
  updatedAt        DateTime?          @updatedAt @map("updated_at") @db.Timestamptz(6)  
  isActive         Boolean           @default(true)  @map("is_active")
  role             String?           @default("user")
  imageUrl         String?            @map("image_url")
  userActivity     UserActivity[]
  userBookmarks    UserBookmark[]
  userCollections  UserCollection[]

  @@map("users")
}
